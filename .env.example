# Copy this file to ".env" and fill in real values before running the server.

# Port the server listens on
PORT=3000

# Long random string used to sign admin login sessions
SESSION_SECRET=change_this_to_a_long_random_string

# First admin account (created automatically the first time the server starts)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# --- Pinterest Developer App credentials ---
# Create an app at https://developers.pinterest.com/apps/
# Add this exact Redirect URI in the Pinterest app settings:
#   http://localhost:3000/auth/pinterest/callback
# (replace localhost:3000 with your real domain once deployed)
PINTEREST_APP_ID=your_pinterest_app_id
PINTEREST_APP_SECRET=your_pinterest_app_secret
PINTEREST_REDIRECT_URI=http://localhost:3000/auth/pinterest/callback

# Base URL of this site (used to build the redirect URI above automatically if needed)
BASE_URL=http://localhost:3000

# --- AI product assistant (Upload/Edit page "AI Suggest" + Dashboard "Trend research") ---
# Get a key at https://console.anthropic.com — without this, the rest of the
# admin panel still works fine, the AI buttons just show a setup message.
ANTHROPIC_API_KEY=your_anthropic_api_key
# Optional: override the model used for suggestions (defaults to claude-sonnet-5)
AI_MODEL=claude-sonnet-5
